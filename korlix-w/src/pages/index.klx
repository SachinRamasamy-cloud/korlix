          div .space-y-3 .mb-8:
            p .text-[#94a3b8] .text-sm "✓ Unlimited projects"
            p .text-[#94a3b8] .text-sm "✓ Full compiler"
            p .text-[#94a3b8] .text-sm "✓ All components"
            p .text-[#94a3b8] .text-sm "✓ Hot drop"
            p .text-[#475569] .text-sm "✗ Priority support"
          button .w-full .py-3 .rounded-xl .text-[#a78bfa] .border .border-[rgba(124,58,237,0.4)] .hover:bg-[rgba(124,58,237,0.1)] "Get started free"

        # Pro tier (featured)
        div .p-8 .rounded-2xl .border .border-[rgba(124,58,237,0.5)] .relative .bg-[rgba(124,58,237,0.05)] .shadow-[0_0_60px_rgba(124,58,237,0.2)]:
          div .absolute .top-[-12px] .left-1/2 .translate-x-[-50%] .px-4 .py-1 .rounded-full .text-xs .font-bold .bg-[linear-gradient(135deg,#7c3aed,#059669)] .text-white "MOST POPULAR"
          p .text-[#a78bfa] .text-sm .font-semibold .mb-4 "PRO"
          div .flex .items-baseline .gap-1 .mb-1:
            span .text-5xl .font-black .text-white "$19"
            span .text-[#64748b] " /mo"
          p .text-[#64748b] .text-sm .mb-8 "billed monthly"
          div .space-y-3 .mb-8:
            p .text-[#94a3b8] .text-sm "✓ Everything in Hobby"
            p .text-[#94a3b8] .text-sm "✓ Priority support"
            p .text-[#94a3b8] .text-sm "✓ VS Code extension"
            p .text-[#94a3b8] .text-sm "✓ LSP server"
            p .text-[#94a3b8] .text-sm "✓ Private templates"
          button .w-full .py-3 .rounded-xl .text-white .font-semibold .bg-[linear-gradient(135deg,#7c3aed,#6d28d9)] .hover:opacity-90 "Upgrade to Pro" on:click:
            toast success "Pro plan — coming soon!"

        # Enterprise tier
        div .p-8 .rounded-2xl .bg-[#0d0b1e] .border .border-[rgba(217,119,6,0.2)]:
          p .text-[#fbbf24] .text-sm .font-semibold .mb-4 "ENTERPRISE"
          p .text-5xl .font-black .text-white .mb-1 "Custom"
          p .text-[#64748b] .text-sm .mb-8 "contact us"
          div .space-y-3 .mb-8:
            p .text-[#94a3b8] .text-sm "✓ Everything in Pro"
            p .text-[#94a3b8] .text-sm "✓ Custom components"
            p .text-[#94a3b8] .text-sm "✓ Team seats"
            p .text-[#94a3b8] .text-sm "✓ SLA guarantee"
            p .text-[#94a3b8] .text-sm "✓ Dedicated support"
          button .w-full .py-3 .rounded-xl .text-[#fbbf24] .border .border-[rgba(217,119,6,0.4)] .hover:bg-[rgba(217,119,6,0.1)] "Contact sales" on:click:
            toast info "Contact us at hello@korlix.dev"

